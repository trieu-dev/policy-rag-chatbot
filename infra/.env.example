# Copy this to .env and fill in your values
# Never commit .env to git — it is in .gitignore

# Claude (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...
# Optional: Set this to use a local LLM (Ollama/Groq) instead of Anthropic
# Ollama: http://localhost:11434/v1/chat/completions
# Groq:   https://api.groq.com/openai/v1/chat/completions
ANTHROPIC_ENDPOINT=
# Ollama model: llama3 (or mistral, gemma, etc.)
ANTHROPIC_MODEL=

# Embeddings (choose one)
OPENAI_API_KEY=sk-...          # for text-embedding-3-small
# Optional: Set this to use local embeddings (Ollama)
# Ollama: http://localhost:11434/v1/embeddings
OPENAI_ENDPOINT=
# Ollama embedding model: nomic-embed-text
OPENAI_MODEL=
# VOYAGE_API_KEY=pa-...        # alternative: voyage-3

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                # leave empty for local, fill for Qdrant Cloud

# Redis
REDIS_CONNECTION=localhost:6379

# JWT (generate a random 256-bit secret)
# openssl rand -base64 32
JWT_SECRET=REPLACE_WITH_RANDOM_SECRET
JWT_EXPIRY_MINUTES=60

# Observability — Langfuse (https://langfuse.com)
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Reranking — Cohere (Week 6)
COHERE_API_KEY=                # optional until Week 6
